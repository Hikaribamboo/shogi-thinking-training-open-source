+#import "YaneuraOuNativeEngine.h"
+
+#include <memory>
+#include <string>
+
+#include "YaneuraOuReadyEngineCore.h"
+
+NS_ASSUME_NONNULL_BEGIN
+
+namespace {
+
+NSString *StringFromStdString(const std::string &value) {
+  return [[NSString alloc] initWithBytes:value.data()
+                                  length:value.size()
+                                encoding:NSUTF8StringEncoding] ?: @"";
+}
+
+NSString *ResolveBundleEvalDirectory(void) {
+  NSURL *evalFileURL = [NSBundle.mainBundle URLForResource:@"nn" withExtension:@"bin" subdirectory:@"eval"];
+  if (evalFileURL != nil) {
+    return evalFileURL.URLByDeletingLastPathComponent.path ?: @"";
+  }
+
+  NSString *resourcePath = NSBundle.mainBundle.resourcePath ?: @"";
+  return [resourcePath stringByAppendingPathComponent:@"eval"];
+}
+
+NSString *ResolveBundleEvalFilePath(void) {
+  NSURL *evalFileURL = [NSBundle.mainBundle URLForResource:@"nn" withExtension:@"bin" subdirectory:@"eval"];
+  return evalFileURL.path ?: @"";
+}
+
+std::string StdStringFromNSString(NSString *value) {
+  return value != nil ? std::string(value.UTF8String ?: "") : std::string();
+}
+
+}  // namespace
+
+@interface YaneuraOuNativeEngine () {
+  @private
+  std::unique_ptr<YaneuraOuIOS::NativeEngineCore> _core;
+}
+@end
+
+@implementation YaneuraOuNativeEngine
+
+- (instancetype)init {
+  self = [super init];
+  if (self != nil) {
+    NSString *binaryPath = NSBundle.mainBundle.executablePath ?: @"";
+    NSString *evalDirectory = ResolveBundleEvalDirectory();
+    NSString *evalFilePath = ResolveBundleEvalFilePath();
+    _core = std::make_unique<YaneuraOuIOS::NativeEngineCore>(
+        StdStringFromNSString(binaryPath),
+        StdStringFromNSString(evalDirectory),
+        StdStringFromNSString(evalFilePath));
+  }
+  return self;
+}
+
+- (YaneuraOuNativeReadyResult *)runReadyHandshake {
+  const YaneuraOuIOS::ReadyCheckResult result = _core->runReadyHandshake();
+  return [[YaneuraOuNativeReadyResult alloc] initWithSuccess:result.success
+                                                     sawUsiOk:result.sawUsiOk
+                                                   sawReadyOk:result.sawReadyOk
+                                                        phase:StringFromStdString(result.phase)
+                                                      summary:StringFromStdString(result.summary)
+                                                   transcript:StringFromStdString(result.transcript)
+                                                evalDirectory:StringFromStdString(result.evalDir)
+                                                 evalFilePath:StringFromStdString(result.evalFilePath)];
+}
+
+- (void)setPositionStartpos {
+  _core->setPositionStartpos();
+}
+
+- (void)setPositionSfen:(NSString *)positionSfen {
+  _core->setPositionSfen(StdStringFromNSString(positionSfen));
+}
+
+- (NSString *)currentPositionCommand {
+  return StringFromStdString(_core->currentPositionCommand());
+}
+
+- (YaneuraOuNativeBestmoveResult *)goDepth1 {
+  const YaneuraOuIOS::BestmoveSearchResult result = _core->goDepth1();
+  return [[YaneuraOuNativeBestmoveResult alloc] initWithSuccess:result.success
+                                                      sawUsiOk:result.sawUsiOk
+                                                    sawReadyOk:result.sawReadyOk
+                                                   sawBestmove:result.sawBestmove
+                                                         phase:StringFromStdString(result.phase)
+                                                       summary:StringFromStdString(result.summary)
+                                                    transcript:StringFromStdString(result.transcript)
+                                               positionCommand:StringFromStdString(result.positionCommand)
+                                                     goCommand:StringFromStdString(result.goCommand)
+                                                      bestmove:StringFromStdString(result.bestmove)
+                                                 evalDirectory:StringFromStdString(result.evalDir)
+                                                  evalFilePath:StringFromStdString(result.evalFilePath)];
+}
+
+- (YaneuraOuNativeBestmoveResult *)analyzeStartpos {
+  const YaneuraOuIOS::BestmoveSearchResult result = _core->analyzeStartpos();
+  return [[YaneuraOuNativeBestmoveResult alloc] initWithSuccess:result.success
+                                                      sawUsiOk:result.sawUsiOk
+                                                    sawReadyOk:result.sawReadyOk
+                                                   sawBestmove:result.sawBestmove
+                                                         phase:StringFromStdString(result.phase)
+                                                       summary:StringFromStdString(result.summary)
+                                                    transcript:StringFromStdString(result.transcript)
+                                               positionCommand:StringFromStdString(result.positionCommand)
+                                                     goCommand:StringFromStdString(result.goCommand)
+                                                      bestmove:StringFromStdString(result.bestmove)
+                                                 evalDirectory:StringFromStdString(result.evalDir)
+                                                  evalFilePath:StringFromStdString(result.evalFilePath)];
+}
+
+- (YaneuraOuNativeBestmoveResult *)analyzePositionSfen:(NSString *)positionSfen {
+  const YaneuraOuIOS::BestmoveSearchResult result = _core->analyzePositionSfen(
+      StdStringFromNSString(positionSfen));
+  return [[YaneuraOuNativeBestmoveResult alloc] initWithSuccess:result.success
+                                                      sawUsiOk:result.sawUsiOk
+                                                    sawReadyOk:result.sawReadyOk
+                                                   sawBestmove:result.sawBestmove
+                                                         phase:StringFromStdString(result.phase)
+                                                       summary:StringFromStdString(result.summary)
+                                                    transcript:StringFromStdString(result.transcript)
+                                               positionCommand:StringFromStdString(result.positionCommand)
+                                                     goCommand:StringFromStdString(result.goCommand)
+                                                      bestmove:StringFromStdString(result.bestmove)
+                                                 evalDirectory:StringFromStdString(result.evalDir)
+                                                  evalFilePath:StringFromStdString(result.evalFilePath)];
+}
+
+- (void)shutdown {
+  _core->shutdown();
+}
+
++ (YaneuraOuNativeReadyResult *)runReadyCheck {
+  YaneuraOuNativeEngine *engine = [[YaneuraOuNativeEngine alloc] init];
+  YaneuraOuNativeReadyResult *result = [engine runReadyHandshake];
+  [engine shutdown];
+  return result;
+}
+
+@end
+
+NS_ASSUME_NONNULL_END

