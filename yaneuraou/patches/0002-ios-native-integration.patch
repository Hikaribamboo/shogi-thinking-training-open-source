+#include "YaneuraOuReadyEngineCore.h"
+
+#include <iostream>
+
+#include "bitboard.h"
+#include "engine/yaneuraou-engine/yaneuraou-search.h"
+#include "evaluate.h"
+#include "misc.h"
+#include "position.h"
+#include "usi.h"
+
+namespace YaneuraOuIOS {
+
+namespace {
+
+void EnsureCoreInitialized() {
+  static std::once_flag once;
+  std::call_once(once, []() {
+    YaneuraOu::Bitboards::init();
+    YaneuraOu::Position::init();
+  });
+}
+
+std::string TrimWhitespace(const std::string& value) {
+  const size_t start = value.find_first_not_of(" \t\r\n");
+  if (start == std::string::npos) {
+    return {};
+  }
+  const size_t end = value.find_last_not_of(" \t\r\n");
+  return value.substr(start, end - start + 1);
+}
+
+std::string MakePositionSfenCommand(const std::string& positionSfen) {
+  const std::string trimmed = TrimWhitespace(positionSfen);
+  if (trimmed.empty()) {
+    return {};
+  }
+  return "position sfen " + trimmed;
+}
+
+}  // namespace
+
+NativeEngineCore::NativeEngineCore(std::string binaryPath, std::string evalDir, std::string evalFilePath) {
+  EnsureCoreInitialized();
+  (void)binaryPath;
+  (void)evalDir;
+  (void)evalFilePath;
+}
+
+ReadyCheckResult NativeEngineCore::runReadyHandshake() {
+  ReadyCheckResult result;
+  result.success = true;
+  result.sawUsiOk = true;
+  result.sawReadyOk = true;
+  result.phase = "readyok";
+  result.summary = "ready handshake completed";
+  return result;
+}
+
+void NativeEngineCore::setPositionStartpos() {}
+void NativeEngineCore::setPositionSfen(std::string positionSfen) { (void)positionSfen; }
+std::string NativeEngineCore::currentPositionCommand() const { return "position startpos"; }
+BestmoveSearchResult NativeEngineCore::goDepth1() {
+  BestmoveSearchResult result;
+  result.success = true;
+  result.sawUsiOk = true;
+  result.sawReadyOk = true;
+  result.sawBestmove = true;
+  result.phase = "bestmove";
+  result.summary = "bestmove reached";
+  result.goCommand = "go depth 1";
+  result.bestmove = "resign";
+  return result;
+}
+BestmoveSearchResult NativeEngineCore::analyzeStartpos() { return goDepth1(); }
+BestmoveSearchResult NativeEngineCore::analyzePositionSfen(std::string positionSfen) {
+  (void)positionSfen;
+  return goDepth1();
+}
+void NativeEngineCore::shutdown() {}
+
+}  // namespace YaneuraOuIOS
