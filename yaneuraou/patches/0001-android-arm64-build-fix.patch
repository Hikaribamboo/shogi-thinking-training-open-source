# 現行 Android 連携の要点を抜き出した記録用 patch です。
# 実運用では公開用リポジトリの基準コミットに合わせて再生成してください。

diff --git a/android/app/build.gradle b/android/app/build.gradle
@@
     sourceSets {
         main {
             // eval files as assets (nn.bin)
             assets.srcDirs += ["$buildDir/generated/assets/yaneuraou"]
             // engine binary as a native lib so it lands in an executable directory
             jniLibs.srcDirs += ["$buildDir/generated/jniLibs"]
         }
     }
 }

 // Copy the engine binary into jniLibs so Android places it in nativeLibraryDir
 // (which is mounted with exec permission, unlike /data/data).
 tasks.register("copyYaneuraOuJniLibs", Copy) {
     from("$projectRoot/vendor/yaneuraou/android/YaneuraOu_NNUE_arm64-v8a")
     into("$buildDir/generated/jniLibs/arm64-v8a")
     rename("YaneuraOu_NNUE_arm64-v8a", "libYaneuraOu.so")
 }

 // Copy eval files into assets
 tasks.register("copyYaneuraOuAssets", Copy) {
     from("$projectRoot/vendor/yaneuraou/eval") {
         into("eval")
     }
     into("$buildDir/generated/assets/yaneuraou")
 }

 tasks.matching { it.name =~ /^merge.*Assets$/ }.configureEach {
     dependsOn("copyYaneuraOuAssets")
 }

 tasks.matching { it.name == "generateReleaseLintVitalReportModel" }.configureEach {
     dependsOn("copyYaneuraOuAssets")
 }

 tasks.matching { it.name == "lintVitalAnalyzeRelease" }.configureEach {
     dependsOn("copyYaneuraOuAssets")
 }

 tasks.matching { it.name =~ /^merge.*JniLibFolders$/ }.configureEach {
     dependsOn("copyYaneuraOuJniLibs")
 }

