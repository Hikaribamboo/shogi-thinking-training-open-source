+#pragma once
+
+#include <string>
+
+namespace YaneuraOuIOS {
+
+struct ReadyCheckResult {
+  bool success = false;
+  bool sawUsiOk = false;
+  bool sawReadyOk = false;
+  std::string phase;
+  std::string summary;
+  std::string transcript;
+  std::string evalDir;
+  std::string evalFilePath;
+};
+
+struct BestmoveSearchResult {
+  bool success = false;
+  bool sawUsiOk = false;
+  bool sawReadyOk = false;
+  bool sawBestmove = false;
+  std::string phase;
+  std::string summary;
+  std::string transcript;
+  std::string positionCommand;
+  std::string goCommand;
+  std::string bestmove;
+  std::string evalDir;
+  std::string evalFilePath;
+};
+
+class NativeEngineCore {
+ public:
+  NativeEngineCore(std::string binaryPath, std::string evalDir, std::string evalFilePath);
+  ReadyCheckResult runReadyHandshake();
+  void setPositionStartpos();
+  void setPositionSfen(std::string positionSfen);
+  std::string currentPositionCommand() const;
+  BestmoveSearchResult goDepth1();
+  BestmoveSearchResult analyzeStartpos();
+  BestmoveSearchResult analyzePositionSfen(std::string positionSfen);
+  void shutdown();
+};
+
+}  // namespace YaneuraOuIOS

diff --git a/ios/app/YaneuraOu/YaneuraOuReadyEngineCore.cpp b/ios/app/YaneuraOu/YaneuraOuReadyEngineCore.cpp
