+#import "YaneuraOuNativeBootstrap.h"
+
+#include <mutex>
+
+#if defined(SHOGI_YANEURAOU_IOS_ENABLED)
+#include "../../../vendor/yaneuraou/ios/source/bitboard.h"
+#include "../../../vendor/yaneuraou/ios/source/position.h"
+#endif
+
+@implementation YaneuraOuNativeBootstrapResult
+
+- (instancetype)initWithSuccess:(BOOL)success
+                        summary:(NSString *)summary
+                     engineInfo:(NSString *)engineInfo
+                binaryDirectory:(NSString *)binaryDirectory
+                   evalFilePath:(NSString *)evalFilePath {
+  self = [super init];
+  if (!self) {
+    return nil;
+  }
+
+  _success = success;
+  _summary = [summary copy];
+  _engineInfo = [engineInfo copy];
+  _binaryDirectory = [binaryDirectory copy];
+  _evalFilePath = [evalFilePath copy];
+  return self;
+}
+
+@end
+
+namespace {
+
+NSString *const kYaneuraOuEvalDirectory = @"eval";
+
+#if defined(SHOGI_YANEURAOU_IOS_ENABLED)
+std::once_flag gYaneuraOuCoreInitOnce;
+#endif
+
+}  // namespace
+
+@implementation YaneuraOuNativeBootstrap
+
++ (NSString *)bundleEvalDirectoryRelativePath {
+  return kYaneuraOuEvalDirectory;
+}
+
++ (NSString *)bundleEvalFilePath {
+  NSString *evalFilePath = [NSBundle.mainBundle pathForResource:@"nn"
+                                                         ofType:@"bin"
+                                                    inDirectory:kYaneuraOuEvalDirectory];
+  return evalFilePath ?: @"";
+}
+
++ (YaneuraOuNativeBootstrapResult *)runSmokeTest {
+#if !defined(SHOGI_YANEURAOU_IOS_ENABLED)
+  NSString *summary = @"Native wrapper is present, but YaneuraOu C++ is still disabled. Enable SHOGI_YANEURAOU_IOS_ENABLED=1 and add the minimal vendor source set to Compile Sources.";
+  return [[YaneuraOuNativeBootstrapResult alloc] initWithSuccess:NO
+                                                         summary:summary
+                                                      engineInfo:@""
+                                                 binaryDirectory:@""
+                                                    evalFilePath:@""];
+#else
+  std::call_once(gYaneuraOuCoreInitOnce, [] {
+    YaneuraOu::Bitboards::init();
+    YaneuraOu::Position::init();
+  });
+
+  NSString *summary = @"Bitboards::init() and Position::init() completed successfully.";
+
+  return [[YaneuraOuNativeBootstrapResult alloc] initWithSuccess:YES
+                                                         summary:summary
+                                                      engineInfo:@""
+                                                 binaryDirectory:@""
+                                                    evalFilePath:@""];
+#endif
+}
+
+@end

